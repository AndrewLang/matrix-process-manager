{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prism",
  "version": "0.1.0",
  "identifier": "com.andrewlang.prism",
  "build": {
    "beforeDevCommand": "pnpm start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist/prism/browser"
  },
  "app": {
    "windows": [
      {
        "title": "Prism",
        "width": 1152,
        "height": 768,
        "minWidth": 980,
        "minHeight": 640,
        "decorations": false,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Monitor and manage workstation processes and resources.",
    "longDescription": "A desktop utility for monitoring processes, system resources, startup applications, ports, storage, and network activity.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.13",
      "signingIdentity": "-"
    }
  }
}