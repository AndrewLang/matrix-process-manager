{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Matrix Process Manager",
  "version": "0.1.0",
  "identifier": "com.matrix.processmanager",
  "build": {
    "beforeDevCommand": "pnpm start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist/matrix-process-manager/browser"
  },
  "app": {
    "windows": [
      {
        "title": "Matrix Process Manager",
        "width": 1152,
        "height": 768,
        "minWidth": 980,
        "minHeight": 640,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}